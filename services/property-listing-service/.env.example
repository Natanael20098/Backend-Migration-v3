# property-listing-service — Environment Variables
# Copy to .env for local development (never commit .env).
# In Docker Compose, these are sourced from the root .env file.

# ── Database (Supabase PostgreSQL, asyncpg format) ─────────────────────────────
# Use the transaction pooler port (6543). prepareThreshold=0 is enforced by the
# shared database module (prepared_statement_cache_size=0 in asyncpg connect_args).
DATABASE_URL=postgresql+asyncpg://user:password@db.example.supabase.co:6543/postgres

# ── JWT (must match Java monolith and auth-service) ────────────────────────────
JWT_SECRET=change-me-use-a-long-random-string-at-least-32-chars
JWT_EXPIRATION_MS=86400000

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# Auth Service — Environment Variables
# Copy to .env and fill in real values before running locally.

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (asyncpg format).
# Use the transaction pooler port (6543), NOT the direct connection port (5432).
DATABASE_URL=postgresql+asyncpg://user:password@db.example.supabase.co:6543/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# HMAC-SHA256 signing secret. Must be identical to the Java monolith's JWT_SECRET.
JWT_SECRET=change-me-use-a-long-random-string

# Token lifetime in milliseconds. Default: 86400000 (24 hours).
JWT_EXPIRATION_MS=86400000

# ── Mailgun ───────────────────────────────────────────────────────────────────
# Mailgun API key (starts with "key-...").
MAILGUN_API_KEY=key-your-mailgun-api-key

# Mailgun sending domain. Must be verified in your Mailgun account.
MAILGUN_DOMAIN=mg.tallerlabs.ai

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend origin that is allowed to make cross-origin requests.
FRONTEND_URL=http://localhost:3000

# ── OTP Settings (optional — defaults shown) ──────────────────────────────────
# OTP_EXPIRY_MINUTES=10
# OTP_RATE_LIMIT_PER_HOUR=5

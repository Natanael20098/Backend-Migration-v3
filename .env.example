# HomeLend Pro Platform — Environment Variables
# Copy to .env and fill in real values before running locally.
# This file is safe to commit; .env is gitignored.

# ── Database (shared by all FastAPI services) ─────────────────────────────────
# Supabase PostgreSQL — asyncpg format.
# Use the transaction pooler port (6543).
DATABASE_URL=postgresql+asyncpg://user:password@db.example.supabase.co:6543/postgres

# ── JWT (must be identical across ALL services) ───────────────────────────────
JWT_SECRET=change-me-use-a-long-random-string-at-least-32-chars

# Token lifetime in milliseconds. Default: 86400000 (24 hours).
JWT_EXPIRATION_MS=86400000

# ── Mailgun ───────────────────────────────────────────────────────────────────
MAILGUN_API_KEY=key-your-mailgun-api-key
MAILGUN_DOMAIN=mg.tallerlabs.ai

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# Allowed origin for CORS on FastAPI services.
FRONTEND_URL=http://localhost:3000

# API base URL baked into the Next.js bundle at build time.
# When running via Docker Compose, the frontend calls the nginx gateway on port 80.
NEXT_PUBLIC_API_URL=http://localhost
